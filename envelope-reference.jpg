@font-face {
  font-family: "Asfire";
  src: url("../fonts/Asfire.woff2") format("woff2");
  font-display: swap;
}

@font-face {
  font-family: "Playfair Display";
  src: url("../fonts/PlayfairDisplay-Regular.ttf") format("truetype");
  font-display: swap;
}

:root {
  --bg: #f4eee8;
  --paper: #f8f0e6;
  --paper-dark: #e3d4c7;
  --paper-edge: #87698d;
  --ink: #6b5070;
  --ink-dark: #3a2c3e;
  --line: #8c6a91;
  --soft-line: rgba(140, 106, 145, .48);
  --card: rgba(255, 249, 242, .74);
  --shadow: rgba(72, 53, 75, .16);
}

* { box-sizing: border-box; }
html, body { min-height: 100%; }
body {
  margin: 0;
  overflow: hidden;
  background: var(--bg);
  color: var(--ink-dark);
  font-family: "Playfair Display", Georgia, serif;
}

.home {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100svh;
  overflow: hidden;
  background:
    radial-gradient(circle at 14% 8%, rgba(255,255,255,.9), transparent 30%),
    radial-gradient(circle at 84% 20%, rgba(207,190,211,.28), transparent 34%),
    linear-gradient(145deg, #f8f3ed 0%, #efe6df 58%, #e9dde5 100%);
}

.home::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("../img/envelope-reference.jpg");
  background-size: cover;
  background-position: center top;
  opacity: .055;
  filter: blur(2px) saturate(.88);
  transform: scale(1.03);
}

.home__art,
.envelope-area,
.menu {
  position: absolute;
  z-index: 2;
}

.home__art {
  inset: 0;
  pointer-events: none;
}

.wash {
  position: absolute;
  border-radius: 999px;
  filter: blur(22px);
  opacity: .42;
}

.wash--top {
  width: 70vw;
  height: 30vh;
  left: 12vw;
  top: 9vh;
  background: rgba(195, 213, 223, .45);
}

.wash--right {
  width: 44vw;
  height: 72vh;
  right: -18vw;
  top: 14vh;
  background: rgba(184, 151, 188, .32);
}

.church {
  position: absolute;
  left: -12vw;
  bottom: -2vh;
  width: min(86vw, 560px);
  max-width: none;
  opacity: .74;
  mix-blend-mode: multiply;
  filter: saturate(.9) contrast(.96);
}

.branch {
  position: absolute;
  width: 90px;
  height: 330px;
  opacity: .68;
  border-left: 2px solid rgba(133, 99, 138, .34);
  transform-origin: bottom center;
}

.branch::before,
.branch::after {
  content: "";
  position: absolute;
  width: 24px;
  height: 46px;
  border-radius: 80% 15% 80% 15%;
  background: rgba(135, 101, 139, .34);
  box-shadow:
    16px 34px 0 rgba(135, 101, 139, .28),
    -2px 70px 0 rgba(135, 101, 139, .31),
    18px 108px 0 rgba(135, 101, 139, .26),
    2px 146px 0 rgba(135, 101, 139, .28),
    17px 184px 0 rgba(135, 101, 139, .22),
    0 222px 0 rgba(135, 101, 139, .22);
}

.branch::before { left: -30px; top: 14px; transform: rotate(-42deg); }
.branch::after { left: 8px; top: 32px; transform: rotate(42deg); }
.branch--left { left: 3vw; top: 12vh; transform: rotate(-18deg); }
.branch--right { right: -18px; top: 2vh; transform: rotate(15deg); }

.envelope-area {
  top: max(20px, env(safe-area-inset-top));
  left: 50%;
  width: min(86vw, 460px);
  transform: translateX(-50%);
  text-align: center;
}

.envelope-button {
  appearance: none;
  border: 0;
  background: transparent;
  width: 100%;
  padding: 0;
  cursor: pointer;
  color: var(--ink);
  -webkit-tap-highlight-color: transparent;
}

.envelope {
  position: relative;
  display: block;
  width: 100%;
  aspect-ratio: 2.1 / 1;
  margin: 0 auto 18px;
  perspective: 1000px;
}

.envelope__shadow {
  position: absolute;
  left: 7%;
  right: 7%;
  bottom: -7%;
  height: 20%;
  border-radius: 50%;
  background: rgba(60, 42, 63, .15);
  filter: blur(15px);
}

.envelope__back,
.envelope__flap,
.envelope__seal {
  position: absolute;
  display: block;
}

.envelope__back {
  inset: 17% 5% 10%;
  background: linear-gradient(135deg, #fbf4eb 0%, #efe3d5 58%, #dfd0c1 100%);
  border: 1px solid rgba(132, 100, 138, .38);
  box-shadow: 0 14px 28px var(--shadow);
}

.envelope__flap {
  inset: 17% 5% 10%;
  background: linear-gradient(145deg, #fff8ef 0%, #eadccf 100%);
  border: 1px solid rgba(132, 100, 138, .38);
}

.envelope__flap--top {
  clip-path: polygon(0 0, 50% 60%, 100% 0, 50% 100%);
  transform-origin: 50% 0%;
  z-index: 5;
  transition: transform 900ms cubic-bezier(.2,.78,.18,1), filter 900ms ease;
}

.envelope__flap--left {
  clip-path: polygon(0 0, 50% 50%, 0 100%);
  z-index: 4;
}

.envelope__flap--right {
  clip-path: polygon(100% 0, 50% 50%, 100% 100%);
  z-index: 4;
}

.envelope__flap--bottom {
  clip-path: polygon(0 100%, 50% 48%, 100% 100%);
  z-index: 6;
  background: linear-gradient(180deg, #f4e9dd 0%, #efe2d5 100%);
}

.envelope__seal {
  width: 16%;
  aspect-ratio: 1;
  left: 42%;
  top: 48%;
  z-index: 8;
  border-radius: 50%;
  background:
    radial-gradient(circle at 40% 35%, rgba(255,255,255,.18), transparent 26%),
    radial-gradient(circle, #94779c 0 47%, #775a81 49% 62%, #a78cad 63% 66%, #6f5278 68%);
  box-shadow: 0 5px 13px rgba(54, 38, 58, .28);
}

.envelope__seal::after {
  content: "✤";
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  color: rgba(246, 236, 230, .62);
  font-size: clamp(13px, 4vw, 22px);
}

.ornament {
  display: block;
  margin-top: -1px;
  color: #87618c;
  font-size: 18px;
  opacity: .88;
}

.tap-text {
  display: block;
  margin-top: 10px;
  color: #87618c;
  font-family: "Playfair Display", Georgia, serif;
  font-size: clamp(12px, 3.3vw, 17px);
  letter-spacing: .18em;
  text-transform: uppercase;
}

.menu {
  right: clamp(16px, 5.2vw, 42px);
  top: 38vh;
  width: min(42vw, 360px);
  display: grid;
  gap: clamp(8px, 1.15vh, 13px);
  opacity: 0;
  transform: translateX(22px);
  pointer-events: none;
  transition: opacity 600ms ease, transform 600ms cubic-bezier(.2,.74,.22,1);
}

.menu-card {
  height: clamp(45px, 6.6vh, 62px);
  display: grid;
  grid-template-columns: 44px 1px 1fr 18px;
  align-items: center;
  gap: 13px;
  padding: 0 14px;
  border: 1px solid rgba(132, 100, 138, .56);
  border-radius: 10px;
  background: var(--card);
  box-shadow: 0 7px 18px rgba(79, 57, 82, .08);
  backdrop-filter: blur(4px);
  text-decoration: none;
  color: #76557d;
  font-size: clamp(14px, 2.9vw, 21px);
  letter-spacing: .1em;
  text-transform: uppercase;
  transform: translateX(16px);
  opacity: 0;
}

.menu-card::before {
  content: "";
  width: 1px;
  height: 56%;
  background: rgba(132, 100, 138, .36);
  grid-column: 2;
  grid-row: 1;
}

.menu-card__icon {
  width: 30px;
  height: 30px;
  justify-self: center;
  grid-column: 1;
  display: grid;
  place-items: center;
}

.menu-card__icon svg {
  width: 27px;
  height: 27px;
  stroke: currentColor;
  stroke-width: 1.35;
  stroke-linecap: round;
  stroke-linejoin: round;
  fill: none;
}

.menu-card span:nth-child(2) {
  grid-column: 3;
}

.menu-card__arrow {
  grid-column: 4;
  font-size: 28px;
  line-height: 1;
  opacity: .82;
  margin-top: -2px;
}

body.opened .envelope__flap--top {
  transform: rotateX(170deg);
  filter: brightness(1.02);
}

body.opened .menu {
  opacity: 1;
  transform: translateX(0);
  pointer-events: auto;
}

body.opened .menu-card {
  animation: menuCardIn 520ms cubic-bezier(.18,.72,.24,1) forwards;
}

body.opened .menu-card:nth-child(1) { animation-delay: 80ms; }
body.opened .menu-card:nth-child(2) { animation-delay: 140ms; }
body.opened .menu-card:nth-child(3) { animation-delay: 200ms; }
body.opened .menu-card:nth-child(4) { animation-delay: 260ms; }
body.opened .menu-card:nth-child(5) { animation-delay: 320ms; }
body.opened .menu-card:nth-child(6) { animation-delay: 380ms; }
body.opened .menu-card:nth-child(7) { animation-delay: 440ms; }
body.opened .menu-card:nth-child(8) { animation-delay: 500ms; }

.envelope-button:focus-visible,
.menu-card:focus-visible {
  outline: 2px solid rgba(132, 100, 138, .82);
  outline-offset: 5px;
}

@keyframes menuCardIn {
  to { opacity: 1; transform: translateX(0); }
}

@media (orientation: landscape) and (max-height: 620px) {
  .envelope-area {
    width: min(33vw, 360px);
    left: 23%;
    top: max(22px, env(safe-area-inset-top));
  }

  .church {
    width: min(56vw, 700px);
    left: 5vw;
    bottom: -11vh;
  }

  .menu {
    top: 10vh;
    right: 8vw;
    width: min(34vw, 380px);
    gap: 8px;
  }

  .menu-card {
    height: min(10.2vh, 51px);
    font-size: clamp(13px, 2.1vw, 18px);
  }

  .tap-text { font-size: 12px; }
}

@media (max-width: 460px) and (orientation: portrait) {
  .envelope-area {
    top: max(18px, env(safe-area-inset-top));
    width: 84vw;
  }

  .church {
    width: 92vw;
    left: -17vw;
    bottom: -1vh;
  }

  .menu {
    top: 39.5vh;
    width: min(50vw, 228px);
    right: 15px;
    gap: 9px;
  }

  .menu-card {
    grid-template-columns: 33px 1px 1fr 12px;
    gap: 8px;
    padding: 0 9px;
    height: clamp(44px, 6.45vh, 55px);
    border-radius: 8px;
    font-size: clamp(12px, 3.15vw, 16px);
    letter-spacing: .08em;
  }

  .menu-card__icon { width: 25px; height: 25px; }
  .menu-card__icon svg { width: 23px; height: 23px; }
  .menu-card__arrow { font-size: 22px; }
}

@media (max-width: 360px) and (orientation: portrait) {
  .menu { width: 54vw; right: 11px; top: 40vh; }
  .menu-card { font-size: 11px; }
  .church { width: 96vw; }
}
